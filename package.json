{
  "name": "@sking7/agent-cli-unified",
  "version": "0.1.0",
  "description": "Unified command builder and runner for Codex, Claude Code, Gemini, and Copilot CLI",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "commonjs",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "test": "node --test test/agent-cli.test.js",
    "test:real": "RUN_REAL_AGENT_E2E=1 node --test test/integration.real-agent.test.js",
    "test:all": "npm test && npm run test:real",
    "check": "node --check src/index.js",
    "prepublishOnly": "npm run check && npm test"
  },
  "keywords": [
    "agent",
    "cli",
    "codex",
    "claude",
    "gemini",
    "copilot"
  ],
  "author": "",
