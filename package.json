{
  "name": "@sking7/agent-cli-unified",
  "version": "1.0.5",
  "description": "Unified command builder and runner for Codex, Claude Code, Antigravity, and Copilot CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/agent-cli.test.js",
    "test:real": "npm run build && RUN_REAL_AGENT_E2E=1 node --test test/integration.real-agent.test.js",
    "test:all": "npm test && npm run test:real",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test"
  },
  "keywords": [
    "agent",
    "cli",
    "codex",
    "claude",
    "antigravity",
    "copilot"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cola-sk/agent-cli-unified.git"
  },
  "bugs": {
    "url": "https://github.com/cola-sk/agent-cli-unified/issues"
  },
  "homepage": "https://github.com/cola-sk/agent-cli-unified#readme",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
